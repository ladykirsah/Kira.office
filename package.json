{
  "name": "kira-office",
  "version": "0.0.0",
  "private": true,
  "description": "Admin back-office for a Shopee Thailand seller: products, inventory, offline-first barcode POS, pricing/profit, sales & finance, and (later) Shopee sync.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b packages/core && tsc --noEmit -p apps/api",
    "lint": "prettier --check \"{packages,apps}/**/src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"{packages,apps}/**/src/**/*.{ts,tsx}\"",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:dry": "wrangler deploy --dry-run --outdir .wrangler/dry"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wrangler": "^4"
  }
}
