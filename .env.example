# Build-time and public (non-secret) configuration. Copy to .env where needed.
#
# On Cloudflare, runtime DATA SERVICES are wrangler *bindings*, not env vars:
#   - D1 database      -> binding "DB"      (wrangler.jsonc)
#   - R2 bucket        -> binding "R2"
#   - Workers KV       -> binding "KV"
#   - Queues           -> binding "SHOPEE_QUEUE"
#   - Cloudflare Images-> binding "IMAGES"
# SECRETS go in .dev.vars (local) and `wrangler secret put` (deployed) — see .dev.vars.example.
# Define non-secret config as `vars` in wrangler.jsonc per environment.

# Public app config (safe to expose to the browser)
NEXT_PUBLIC_APP_NAME="L Shopee Back Office"
APP_BASE_URL="http://localhost:8787"

# AirPlus storefront (apps/storefront): base URL for product images — points at the api Worker's
# public GET /img/:key route. Default when unset = https://api.homeseeker.me
NEXT_PUBLIC_IMG_BASE="https://api.homeseeker.me"

# Shop defaults (non-secret; can also live as wrangler vars)
DEFAULT_CURRENCY="THB"
DEFAULT_TIMEZONE="Asia/Bangkok"
DEFAULT_VAT_RATE_BP="700"          # 7.00% as integer basis points
SHOPEE_REGION="TH"
SHOPEE_USE_SANDBOX="true"

# Alternative DB path (only if using Hyperdrive + Postgres instead of D1):
# HYPERDRIVE is a binding; the upstream Postgres URL is a SECRET -> put it in .dev.vars.
